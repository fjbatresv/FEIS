{
  "name": "pdei-ui-library",
  "version": "1.0.0",
  "private": true,
  "description": "Pdei+ vanilla UI library bundle and static documentation site.",
  "scripts": {
    "prebuild": "npm run test:unit",
    "build": "node scripts/build.js",
    "docs": "node scripts/build.js --docs-only",
    "zip": "node scripts/build.js --zip-only",
    "test": "npm run test:unit && npm run test:html && npm run test:assets && npm run test:icons && npm run test:bundle && npm run test:js && npm run test:responsive && npm run test:a11y",
    "test:unit": "jest tests/pdei-source.test.js --runInBand",
    "test:html": "html-validate src/docs/index.html site/index.html",
    "test:assets": "node scripts/check-assets.js",
    "test:icons": "node scripts/check-icons.js",
    "test:bundle": "node scripts/check-bundle-smoke.js",
    "test:js": "playwright test tests/pdei-js.spec.js",
    "test:responsive": "playwright test tests/responsive.spec.js",
    "test:a11y": "playwright test tests/a11y.spec.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "html-validate": "^11.4.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lucide-static": "^1.17.0"
  }
}
